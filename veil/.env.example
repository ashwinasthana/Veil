# ─── Veil Environment Variables ───
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/veil?schema=public"

# Upstash Redis (for rate limiting)
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# Public base URL (used for generating short links)
# In production on Vercel, this is your domain
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# For production: NEXT_PUBLIC_BASE_URL="https://veils.dev"
